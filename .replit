modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx --yes serve -l 5000 ."
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
CLIENT_ORIGINS = "https://vedantamplayschool-byte.github.io"
JWT_COOKIE_EXPIRES_DAYS = "7"
JWT_EXPIRES_IN = "7d"
MAX_FILE_SIZE_MB = "5"
NODE_ENV = "production"
